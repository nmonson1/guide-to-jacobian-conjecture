{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/gjc/schemas/public-export-v2.json",
  "title": "GJC public claim export manifest v2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "export_id",
    "generated_at",
    "as_of",
    "timezone",
    "claim_schema",
    "assessment_policy",
    "files",
    "counts",
    "content_digest"
  ],
  "properties": {
    "schema_version": { "const": 2 },
    "export_id": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}-[a-z0-9][a-z0-9-]*$"
    },
    "generated_at": { "type": "string", "format": "date-time" },
    "as_of": { "type": "string", "format": "date" },
    "timezone": { "const": "America/Los_Angeles" },
    "claim_schema": { "const": "public-claim-v2" },
    "assessment_policy": { "const": "gjc-assessment-v1" },
    "files": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "sha256"],
        "properties": {
          "path": {
            "type": "string",
            "pattern": "^claims/JCG-CLAIM-[0-9]{4,}\\.(json|ya?ml)$"
          },
          "sha256": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$"
          }
        }
      }
    },
    "counts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["total", "by_role", "by_assessment"],
      "properties": {
        "total": { "type": "integer", "minimum": 0 },
        "by_role": {
          "type": "object",
          "additionalProperties": false,
          "required": ["goal", "standalone", "supporting"],
          "properties": {
            "goal": { "type": "integer", "minimum": 0 },
            "standalone": { "type": "integer", "minimum": 0 },
            "supporting": { "type": "integer", "minimum": 0 }
          }
        },
        "by_assessment": {
          "type": "object",
          "additionalProperties": false,
          "required": ["open", "proof_offered", "verified", "disproved"],
          "properties": {
            "open": { "type": "integer", "minimum": 0 },
            "proof_offered": { "type": "integer", "minimum": 0 },
            "verified": { "type": "integer", "minimum": 0 },
            "disproved": { "type": "integer", "minimum": 0 }
          }
        }
      }
    },
    "content_digest": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "note": { "type": "string", "minLength": 1 }
  }
}
